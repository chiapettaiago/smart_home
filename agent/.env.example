SERVER_URL=http://192.168.1.10:8100
WEBSOCKET_URL=ws://192.168.1.10:8100/ws/agents
AGENT_TOKEN=troque-por-um-token-aleatorio-com-pelo-menos-32-caracteres

AGENT_DATA_DIR=C:\ProgramData\SmartHomeAgent
HEARTBEAT_INTERVAL_SECONDS=15
RECONNECT_MIN_SECONDS=2
RECONNECT_MAX_SECONDS=60
HTTP_TIMEOUT_SECONDS=10
VERIFY_TLS=true

LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
PROCESS_LIST_LIMIT=250

ALLOWED_PROGRAMS_JSON={"chrome":"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe","notepad":"C:\\Windows\\System32\\notepad.exe","vscode":"%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\Code.exe","steam":"C:\\Program Files (x86)\\Steam\\steam.exe"}
ALLOWED_PROCESSES=chrome.exe,notepad.exe,Code.exe,steam.exe

# Vazio permite qualquer host HTTP(S). Em produção, prefira uma lista explícita.
ALLOWED_URL_HOSTS=www.youtube.com,netflix.com,www.netflix.com
